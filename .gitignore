# =========================
# Large Data Files (CONTROLLED)
# =========================

# Ignore ALL CSVs by default
*.csv

# Allow attendance logs ONLY
!attendance_logs/
!attendance_logs/*.csv

# Ignore pickle files globally
*.pkl
*.pickle

# Allow embeddings folder INCLUDING pickle files
!embeddings/
!embeddings/**
!embeddings/**/*.pkl
!embeddings/**/*.pickle

# =========================
# Media / Heavy Files
# =========================
*.webm
*.mp4
*.avi

